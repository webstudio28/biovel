<!-- Certificates Lightbox -->
<div
    id="certificate-lightbox"
    class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 opacity-0 pointer-events-none transition-opacity duration-300"
    aria-hidden="true"
>
    <button
        type="button"
        id="certificate-lightbox-close"
        class="absolute top-4 right-4 rounded-full text-white text-3xl p-3 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-evergreen/80"
        aria-label="Затвори изображението"
    >
        ✕
    </button>
    <div class="max-w-[95vw] max-h-[80vh] flex items-center justify-center px-4">
        <img
            id="certificate-lightbox-img"
            src=""
            alt=""
            class="w-full h-full max-w-[95vw] max-h-[80vh] object-contain rounded-2xl shadow-2xl border border-primary-cream/60 bg-black/10"
        >
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const lightbox = document.getElementById('certificate-lightbox');
    const lightboxImg = document.getElementById('certificate-lightbox-img');
    const closeBtn = document.getElementById('certificate-lightbox-close');

    if (!lightbox || !lightboxImg) return;

    const openLightbox = (src, alt) => {
        lightboxImg.src = src;
        lightboxImg.alt = alt || '';
        lightbox.classList.remove('opacity-0', 'pointer-events-none');
        lightbox.classList.add('opacity-100');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
        lightbox.classList.add('opacity-0', 'pointer-events-none');
        lightbox.classList.remove('opacity-100');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    };

    document.querySelectorAll('[data-certificate-full]').forEach((el) => {
        el.addEventListener('click', () => {
            const src = el.getAttribute('data-certificate-full');
            const alt = el.getAttribute('data-certificate-alt');
            if (src) {
                openLightbox(src, alt);
            }
        });
    });

    if (closeBtn) {
        closeBtn.addEventListener('click', closeLightbox);
    }

    lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) {
            closeLightbox();
        }
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            closeLightbox();
        }
    });
});
</script>
